{
  "name": "api-webhook",
  "version": "1.0.0",
  "description": "Integración entre sistemas vía API y Webhooks con Express, TypeScript, Drizzle ORM y PostgreSQL",
  "main": "dist/server.js",
  "directories": {
    "doc": "docs",
    "src": "src",
    "db": "db"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx scripts/demo.ts",
    "socket:test": "tsx scripts/socket-client.ts"
  },
  "keywords": [
    "express",
    "typescript",
    "drizzle",
    "postgresql",
    "webhook",
    "socket.io"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/socket.io-client": "^1.4.36",
    "@types/supertest": "^7.2.1",
    "drizzle-kit": "^0.31.10",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^7.0.2",
    "vitest": "^3.2.4"
  }
}
