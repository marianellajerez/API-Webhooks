{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Target & Module */
    "target": "ES2020",
    "module": "commonjs",
    "types": ["node"],
    "esModuleInterop": true,

    /* Source Map & Declarations */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Strict Type Checking */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
  }
}
